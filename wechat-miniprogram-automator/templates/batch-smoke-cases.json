{
  "defaults": {
    "beforeEach": [
      {
        "type": "reLaunch",
        "url": "{{ROUTE_URL}}"
      }
    ]
  },
  "cases": [
    {
      "name": "snapshot-and-selector",
      "actions": [
        {
          "type": "waitForRoute",
          "path": "{{ROUTE_PATH}}",
          "query": "{{ROUTE_QUERY}}",
          "timeoutMs": "{{ROUTE_TIMEOUT_MS}}"
        },
        {
          "type": "snapshot",
          "dataPaths": "{{SNAPSHOT_DATA_PATHS}}",
          "path": "{{SNAPSHOT_PATH}}"
        },
        {
          "type": "waitForSelector",
          "selector": "{{READY_SELECTOR}}",
          "timeoutMs": "{{READY_TIMEOUT_MS}}"
        }
      ]
    },
    {
      "name": "selector-and-screenshot",
      "actions": [
        {
          "type": "waitForSelector",
          "selector": "{{READY_SELECTOR}}",
          "timeoutMs": "{{READY_TIMEOUT_MS}}"
        },
        {
          "type": "screenshot",
          "path": "{{SCREENSHOT_PATH}}"
        }
      ]
    }
  ]
}
